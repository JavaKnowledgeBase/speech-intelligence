# ─── TalkBuddy AI — Environment Variables ────────────────────────────────────
#
# Copy this file to .env and fill in values before running the server.
# Never commit .env to source control.
#
# Quick-start (no keys needed):
#   All keys are optional. Without them the server runs in mock mode with
#   browser-native speech (Web Speech API) and rule-based output filtering.
#   Browse to http://localhost:8000/therapy for the session UI.
#
# Production checklist:
#   [ ] OPENAI_API_KEY              — scoring, conductor, output filter, TTS
#   [ ] DEEPGRAM_API_KEY            — streaming STT via Deepgram Nova-2
#   [ ] LIVEKIT_URL + keys          — WebRTC transport tokens
#   [ ] SUPABASE_URL + key          — persistent HIPAA audit trail (required for prod)
#   [ ] CLERK_SECRET_KEY            — JWT auth on clinical/caregiver routes
#   [ ] USE_LIVE_PROVIDER_CALLS=true — activates all live provider paths
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production

# Master switch. Set to true in production to activate live provider calls.
# When false: mock transport, local speech scoring, Web Speech API for STT/TTS.
USE_LIVE_PROVIDER_CALLS=false

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Enables: speech turn scoring (gpt-4o-mini), session conductor decisions,
#          output filtering (child-safe message rewriting), TTS streaming (tts-1)
OPENAI_API_KEY=

# ── Deepgram ─────────────────────────────────────────────────────────────────
# Enables: streaming STT via WS /runtime/voice/stream → Deepgram Nova-2 General
#          VAD-based turn detection (endpointing=700ms)
DEEPGRAM_API_KEY=

# ── Hume AI ──────────────────────────────────────────────────────────────────
# Enables: vocal engagement scoring, frustration/fatigue detection
HUME_API_KEY=

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Enables: signed WebRTC transport tokens for browser ↔ LiveKit room handshake
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_PREFIX=talkbuddy         # prepended to room names (default: talkbuddy)
LIVEKIT_TOKEN_TTL_SECONDS=3600        # access token lifetime (default: 1 hour)

# ── Supabase ─────────────────────────────────────────────────────────────────
# Enables: persistent sessions, progress, alerts, reviews, voice transcripts,
#          voice latency checkpoints, vector similarity (pgvector).
#          Run docs/supabase_schema.sql to create all tables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# auto   — use Supabase when configured, in-memory on failure (default)
# always — fail fast if Supabase is unavailable (recommended for production)
# never  — always use in-memory (useful for integration tests)
SUPABASE_REPOSITORY_MODE=memory

# ── Clerk ────────────────────────────────────────────────────────────────────
# Enables: JWT verification on /clinician/*, /caregiver/*, /enterprise/*,
#          /analytics/*, /reports/*, /goals/*, /workflows/*, /alerts/escalate
# Without this key all protected routes are open (dev passthrough mode).
CLERK_SECRET_KEY=

# ── Temporal ─────────────────────────────────────────────────────────────────
# Enables: durable workflow orchestration (reminders, clinician queues,
#          report timers). Optional — in-memory queues used without it.
TEMPORAL_HOST=

# ── Filter microservice (optional) ───────────────────────────────────────────
# When set, output filtering calls this service instead of the local rule engine.
# Used when a dedicated speech-filters microservice is deployed alongside this server.
FILTER_SERVICE_URL=http://host.docker.internal:18100
FILTER_SERVICE_TIMEOUT=3
FILTER_SERVICE_API_KEY=local-prod-key
